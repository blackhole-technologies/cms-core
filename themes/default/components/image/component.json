{
  "name": "image",
  "description": "Responsive image with aspect ratio, border radius, optional caption and link",
  "props": {
    "src": { "type": "string", "required": true },
    "alt": { "type": "string", "default": "" },
    "size": { "type": "string", "default": "4:3", "enum": ["2:1", "16:9", "3:2", "4:3", "1:1"] },
    "radius": { "type": "string", "enum": ["small", "large", "extra-large"] },
    "caption": { "type": "string" },
    "url": { "type": "string", "description": "Optional link" }
  }
}
