{
  "name": "heading",
  "description": "Dynamic heading element with configurable level, size, color, and alignment",
  "props": {
    "heading_text": { "type": "string", "required": true },
    "level": { "type": "number", "default": 2, "enum": [1, 2, 3, 4, 5, 6] },
    "text_size": { "type": "string", "default": "default", "enum": ["default", "8xl", "7xl", "6xl", "5xl", "4xl", "3xl", "2xl", "xl"] },
    "text_color": { "type": "string", "default": "default", "enum": ["default", "inverted", "primary"] },
    "align": { "type": "string", "default": "left", "enum": ["left", "center", "right"] },
    "url": { "type": "string", "description": "Optional link" }
  }
}
