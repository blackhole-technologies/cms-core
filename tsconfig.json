{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "core/**/*.ts",
    "modules/**/*.ts",
    "src/**/*.ts",
    "index.ts",
    "server.ts",
    "build.ts"
  ],
  "exclude": ["node_modules", "public", "themes", "content"]
}
