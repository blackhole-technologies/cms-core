{
  "article": {
    "label": "Article",
    "description": "Use for time-sensitive content like news and blog posts",
    "bundle": "content",
    "locked": false,
    "fields": {
      "title": {
        "type": "string",
        "required": true,
        "minLength": 5,
        "maxLength": 255,
        "weight": 0,
        "label": "Title"
      },
      "body": {
        "type": "richtext",
        "required": false,
        "weight": 10,
        "label": "Body"
      },
      "summary": {
        "type": "text",
        "required": false,
        "weight": 5,
        "label": "Summary",
        "minLength": 1,
        "maxLength": 500
      },
      "slug": {
        "type": "string",
        "required": false,
        "weight": 3,
        "label": "URL Slug",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "patternMessage": "URL Slug must contain only lowercase letters, numbers, and hyphens (e.g., my-article-title)"
      },
      "tags": {
        "type": "string",
        "required": false,
        "weight": 4,
        "label": "Tags",
        "constraints": {
          "Regex": {
            "pattern": "^[a-zA-Z0-9, ]+$",
            "message": "Tags must contain only letters, numbers, commas, and spaces"
          }
        }
      },
      "email": {
        "type": "string",
        "required": false,
        "weight": 6,
        "label": "Email",
        "constraints": {
          "Email": {}
        }
      },
      "website": {
        "type": "string",
        "required": false,
        "weight": 7,
        "label": "Website",
        "constraints": {
          "Url": {}
        }
      },
      "rating": {
        "type": "integer",
        "required": false,
        "weight": 8,
        "label": "Rating",
        "constraints": {
          "Range": {
            "min": 1,
            "max": 100
          }
        }
      },
      "created": {
        "type": "datetime",
        "required": true,
        "weight": 997,
        "label": "Created",
        "readonly": true
      },
      "updated": {
        "type": "datetime",
        "required": true,
        "weight": 998,
        "label": "Updated",
        "readonly": true
      },
      "status": {
        "type": "select",
        "options": ["draft", "published", "archived"],
        "default": "draft",
        "weight": 999,
        "label": "Status"
      }
    },
    "settings": {
      "publishable": true,
      "revisions": true,
      "preview": true
    }
  },
  "page": {
    "label": "Basic Page",
    "description": "Use for static content that rarely changes",
    "bundle": "content",
    "locked": false,
    "fields": {
      "title": {
        "type": "string",
        "required": true,
        "maxLength": 255,
        "weight": 0,
        "label": "Title"
      },
      "body": {
        "type": "richtext",
        "required": false,
        "weight": 10,
        "label": "Body"
      },
      "created": {
        "type": "datetime",
        "required": true,
        "weight": 997,
        "label": "Created",
        "readonly": true
      },
      "updated": {
        "type": "datetime",
        "required": true,
        "weight": 998,
        "label": "Updated",
        "readonly": true
      },
      "status": {
        "type": "select",
        "options": ["draft", "published", "archived"],
        "default": "draft",
        "weight": 999,
        "label": "Status"
      }
    },
    "settings": {
      "publishable": true,
      "revisions": false,
      "preview": false
    }
  }
}
